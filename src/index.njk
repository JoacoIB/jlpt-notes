---
layout: layouts/base.njk
title: Notas de JLPT
---

<section class="study-page">
  <header class="lesson-hero">
    <p class="kicker">Japanese Grammar</p>
    <div class="lesson-heading">
      <div>
        <h1>Notas de JLPT</h1>
        <p class="meaning-line">
          <span>Apuntes de gramática</span>
          <span class="divider">•</span>
          <span>Navegación simple entre estructuras</span>
        </p>
      </div>
    </div>
  </header>

  <section class="content-card">
    <section class="note-section">
      <h2>Apuntes</h2>
      <div class="notes-links">
        {% for entry in collections.all %}
          {% if entry.data.layout == "layouts/notebook-page.njk" %}
            <a href="{{ entry.url | url }}" class="note-link">
              <span>{{ entry.data.titulo }}</span>
              <small>{{ entry.data.jlpt }}</small>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </section>
  </section>
</section>
